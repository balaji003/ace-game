# Server
APP_ENV=dev                       # dev | prod
PORT=8080
# dev: "*" allows LAN devices (phones on the same WiFi) to connect.
# prod: MUST be an explicit origin, e.g. https://yourgame.com (wildcard is refused).
ALLOW_ORIGIN=*

# MySQL
DB_USER=root
DB_PASS=yourpassword
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ace_db

# Auth — generate a long random string, e.g.  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# AI opponents (server-side Anthropic calls)
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514

# OTP rate limiting
OTP_MAX_PER_DAY=5
OTP_COOLDOWN_SECS=30

# Gameplay timers (seconds)
WATCH_COUNTDOWN_SECS=10
AFK_WARN_SECS=20
AFK_GRACE_SECS=10
# Max "I am here" retries on no-response before the card is burned + player pushed out
# (shared by the offline AFK popup and online play)
MAX_TURN_RETRIES=3
# Player-count bounds (total players) — shared by online rooms and the offline lobby.
# Hard limits are 3–7; values outside that range (or invalid) are pinned into it.
MIN_PLAYERS=3
MAX_PLAYERS=7

# History
RECENT_GAMES_LIMIT=10
