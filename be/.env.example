# Server
PORT=8080
ALLOW_ORIGIN=http://localhost:5173

# MySQL
DB_USER=root
DB_PASS=yourpassword
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ace_db

# Auth — generate a long random string, e.g.  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# AI opponents (server-side Anthropic calls)
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514

# OTP rate limiting
OTP_MAX_PER_DAY=5
OTP_COOLDOWN_SECS=30

# Gameplay timers (seconds)
WATCH_COUNTDOWN_SECS=10
AFK_WARN_SECS=20
AFK_GRACE_SECS=10

# History
RECENT_GAMES_LIMIT=10
