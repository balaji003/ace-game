# Production environment example — copy to .env on the deployed host.

# Server
APP_ENV=prod
PORT=8080
# REQUIRED in prod — comma-separated allow-list (wildcard is refused at startup).
# Include the web domain AND the native WebView origin so the mobile apps connect.
ALLOW_ORIGIN=https://yourgame.com,capacitor://localhost

# MySQL
DB_USER=aceuser
DB_PASS=change-me
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ace

# Auth — generate a long random string, e.g.  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# AI opponents (server-side Anthropic calls)
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514

# OTP rate limiting
OTP_MAX_PER_DAY=5
OTP_COOLDOWN_SECS=30

# Gameplay timers (seconds)
WATCH_COUNTDOWN_SECS=10
AFK_WARN_SECS=20
AFK_GRACE_SECS=10
MAX_TURN_RETRIES=3
MIN_PLAYERS=3
MAX_PLAYERS=7

# History
RECENT_GAMES_LIMIT=10
